{
  "name": "@flowguard/core",
  "version": "1.3.0",
  "description": "FlowGuard runtime for OpenCode — deterministic, fail-closed, audit-ready workflow engine.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./integration": {
      "import": "./dist/integration/index.js",
      "types": "./dist/integration/index.d.ts"
    }
  },
  "bin": {
    "flowguard": "./dist/cli/install.js"
  },
  "scripts": {
    "build": "tsc && npm run fix-esm",
    "fix-esm": "node scripts/fix-esm-imports.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@opencode-ai/plugin": "^1.4.3",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED",
  "private": true
}

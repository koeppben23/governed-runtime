{
  "name": "@flowguard/core",
  "version": "1.2.0-rc.3",
  "description": "FlowGuard runtime for OpenCode — deterministic, fail-closed, audit-ready workflow engine.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./integration": {
      "import": "./dist/integration/index.js",
      "types": "./dist/integration/index.d.ts"
    },
    "./integration/tools": {
      "import": "./dist/integration/tools/index.js",
      "types": "./dist/integration/tools/index.d.ts"
    },
    "./integration/plugin": {
      "import": "./dist/integration/plugin.js",
      "types": "./dist/integration/plugin.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    }
  },
  "bin": {
    "flowguard": "./dist/cli/install.js",
    "flowguard-mcp": "./dist/mcp-server/index.js"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.js",
    "build": "npm run clean && npm run sync-version && npm run generate-docs && tsc",
    "check:esm": "node scripts/check-esm-imports.js",
    "check:actions-pinned": "node scripts/check-github-actions-pinned.js",
    "check": "tsc --noEmit",
    "check:unused-dependencies": "knip --dependencies",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"docs/**/*.md\" \"scripts/**/*.js\" \"*.json\" \".github/**/*.yml\"",
    "check:format": "prettier --check \"src/**/*.ts\" \"docs/**/*.md\" \"scripts/**/*.js\" \"*.json\" \".github/**/*.yml\"",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "test": "vitest run --project unit --project integration",
    "test:coverage": "vitest run --project unit --coverage",
    "test:coverage:ci": "vitest run --project unit --silent --coverage --coverage.reporter=json-summary",
    "test:watch": "vitest --project unit --project integration",
    "test:install-verify": "vitest run --project smoke src/cli/install-verify.test.ts",
    "test:acp": "vitest run --project smoke src/cli/run-acp-smoke.test.ts",
    "test:unit": "vitest run --project unit",
    "test:architecture": "vitest run --project unit src/architecture/**/*.test.ts",
    "test:integration": "vitest run --project integration",
    "test:sdk-contract": "vitest run --project integration src/integration/sdk-contract.test.ts",
    "test:smoke": "vitest run --project smoke",
    "test:independent-review-e2e": "node scripts/verify-independent-review-e2e.js",
    "sync-version": "node scripts/sync-version.js",
    "generate-docs": "node scripts/generate-docs.js",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "mutation": "node scripts/stryker-patch.js && stryker run",
    "release:prepare": "node scripts/prepare-release.js",
    "release:verify": "npm run check && npm run lint && npm test && npm run build && npm run check:esm && npm run test:install-verify",
    "release:assert-main-tag": "node scripts/assert-main-release-tag.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "jose": "^6.2.3",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.37.0",
    "@opencode-ai/plugin": "1.15.4",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.4.0",
    "knip": "^6.12.2",
    "prettier": "^3.8.3",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "protobufjs": "7.5.7"
  },
  "files": [
    "dist",
    "VERSION"
  ],
  "license": "SEE LICENSE IN LICENSE"
}

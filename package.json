{
  "name": "@flowguard/core",
  "version": "1.2.0-rc.2",
  "description": "FlowGuard runtime for OpenCode — deterministic, fail-closed, audit-ready workflow engine.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./integration": {
      "import": "./dist/integration/index.js",
      "types": "./dist/integration/index.d.ts"
    },
    "./integration/tools": {
      "import": "./dist/integration/tools/index.js",
      "types": "./dist/integration/tools/index.d.ts"
    },
    "./integration/plugin": {
      "import": "./dist/integration/plugin.js",
      "types": "./dist/integration/plugin.d.ts"
    }
  },
  "bin": {
    "flowguard": "./dist/cli/install.js"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.js",
    "build": "npm run clean && npm run sync-version && npm run generate-docs && tsc",
    "check:esm": "node scripts/check-esm-imports.js",
    "check:actions-pinned": "node scripts/check-github-actions-pinned.js",
    "check": "tsc --noEmit",
    "check:unused-dependencies": "knip --dependencies",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"docs/**/*.md\" \"scripts/**/*.js\" \"*.json\" \".github/**/*.yml\"",
    "check:format": "prettier --check \"src/**/*.ts\" \"docs/**/*.md\" \"scripts/**/*.js\" \"*.json\" \".github/**/*.yml\"",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --exclude 'src/cli/install-verify.test.ts'",
    "test:coverage:ci": "vitest run --silent --coverage --coverage.reporter=json-summary --exclude 'src/cli/install-verify.test.ts' --exclude 'src/cli/cli-contract-smoke.test.ts' --coverage.thresholds.branches=80 --coverage.thresholds.lines=80 --coverage.thresholds.functions=80 --coverage.thresholds.statements=80",
    "test:watch": "vitest",
    "test:install-verify": "vitest run src/cli/install-verify.test.ts",
    "test:acp": "vitest run src/cli/run-acp-smoke.test.ts",
    "test:unit": "vitest run --exclude src/integration/ --exclude src/cli/install-verify.test.ts --exclude src/cli/run-acp-smoke.test.ts --exclude src/cli/cli-contract-smoke.test.ts",
    "test:architecture": "vitest run src/architecture/**/*.test.ts src/architecture-boundary.test.ts",
    "test:integration": "vitest run src/integration/",
    "test:smoke": "vitest run src/cli/run-acp-smoke.test.ts src/cli/cli-contract-smoke.test.ts",
    "test:independent-review-e2e": "node scripts/verify-independent-review-e2e.js",
    "sync-version": "node scripts/sync-version.js",
    "generate-docs": "node scripts/generate-docs.js",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "mutation": "node scripts/stryker-patch.js && stryker run",
    "preversion": "node scripts/sync-version.js && node scripts/generate-docs.js",
    "postversion": "git add package.json README.md PRODUCT_IDENTITY.md docs/ && git commit -m 'chore: sync version from VERSION to package.json and docs'"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "jose": "^5.9.6",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/sdk-node": "^0.216.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.37.0",
    "@opencode-ai/plugin": "^1.14.33",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.37.0",
    "knip": "^6.11.0",
    "prettier": "^3.8.3",
    "typedoc": "^0.28.19",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist",
    "VERSION"
  ],
  "license": "SEE LICENSE IN LICENSE"
}

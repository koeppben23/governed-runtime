{
  "name": "@flowguard/core",
  "version": "1.0.0",
  "description": "FlowGuard runtime for OpenCode — deterministic, fail-closed, audit-ready workflow engine.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./integration": {
      "import": "./dist/integration/index.js",
      "types": "./dist/integration/index.d.ts"
    }
  },
  "bin": {
    "flowguard": "./dist/cli/install.js"
  },
  "scripts": {
    "build": "npm run sync-version && npm run generate-docs && tsc && npm run fix-esm",
    "fix-esm": "node scripts/fix-esm-imports.js",
    "check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "sync-version": "node scripts/sync-version.js",
    "generate-docs": "node scripts/generate-docs.js",
    "preversion": "node scripts/sync-version.js && node scripts/generate-docs.js",
    "postversion": "git add package.json README.md PRODUCT_IDENTITY.md docs/ && git commit -m 'chore: sync version from VERSION to package.json and docs'"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@opencode-ai/plugin": "^1.4.3",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.37.0",
    "typescript-eslint": "^8.46.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "private": true
}

{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": [
    "html",
    "clear-text",
    "progress",
    "json"
  ],
  "coverageAnalysis": "perTest",
  "checkers": [
    "typescript"
  ],
  "tsconfigFile": "tsconfig.json",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "mutate": [
    "src/machine/guards.ts",
    "src/machine/evaluate.ts",
    "src/machine/commands.ts",
    "src/identity/token-verifier.ts",
    "src/rails/review-decision.ts",
    "src/rails/ticket.ts",
    "src/rails/review.ts",
    "src/rails/hydrate.ts",
    "src/audit/integrity.ts",
    "src/audit/completeness.ts",
    "src/config/reasons.ts",
    "src/config/policy.ts",
    "src/presentation/next-action-copy.ts",
    "src/presentation/next-action-copy.ts",
    "src/presentation/plan-review-card.ts",
    "src/presentation/phase-labels.ts",
    "src/integration/command-aliases.ts",
    "src/integration/tool-classification.ts",
    "src/integration/tool-names.ts",
    "src/integration/review-enforcement.ts",
    "src/integration/review-orchestrator.ts",
    "src/integration/status.ts"
  ],
  "ignoreStatic": true,
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 80
  }
}
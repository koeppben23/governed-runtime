{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "progress", "json"],
  "coverageAnalysis": "perTest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutate": ["src/machine/guards.ts", "src/machine/evaluate.ts", "src/identity/token-verifier.ts"],
  "ignoreStatic": true,
  "thresholds": {
    "high": 90,
    "low": 85,
    "break": 85
  }
}

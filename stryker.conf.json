{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "progress", "json"],
  "coverageAnalysis": "perTest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "mutate": [
    "src/adapters/persistence.ts",
    "src/audit/completeness.ts",
    "src/audit/integrity.ts",
    "src/config/reasons.ts",
    "src/identity/token-verifier.ts",
    "src/integration/command-aliases.ts",
    "src/integration/status.ts",
    "src/integration/tool-classification.ts",
    "src/machine/commands.ts",
    "src/machine/evaluate.ts",
    "src/machine/guards.ts",
    "src/machine/next-action.ts",
    "src/rails/architecture.ts",
    "src/rails/hydrate.ts",
    "src/rails/review-decision.ts",
    "src/rails/review.ts",
    "src/rails/ticket.ts"
  ],
  "mutator": {
    "excludedMutations": ["StringLiteral"]
  },
  "ignoreStatic": true,
  "thresholds": {
    "high": 90,
    "low": 60,
    "break": 80
  }
}

{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "progress", "json"],
  "coverageAnalysis": "perTest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "mutate": [
    "src/adapters/persistence.ts",
    "src/audit/completeness.ts",
    "src/audit/integrity.ts",
    "src/config/policy.ts",
    "src/config/reasons.ts",
    "src/identity/token-verifier.ts",
    "src/integration/command-aliases.ts",
    "src/integration/review/enforcement/enforcement.ts",
    "src/integration/review/orchestrator.ts",
    "src/integration/status.ts",
    "src/integration/tool-classification.ts",
    "src/machine/commands.ts",
    "src/machine/evaluate.ts",
    "src/machine/guards.ts",
    "src/machine/next-action.ts",
    "src/rails/architecture.ts",
    "src/rails/hydrate.ts",
    "src/rails/review-decision.ts",
    "src/rails/review.ts",
    "src/rails/ticket.ts",

    "src/integration/plugin-risk.ts",
    "src/integration/plugin-task-evidence.ts",
    "src/integration/plugin-host-task-diagnostics-helpers.ts",

    "src/integration/plugin-audit.ts",
    "src/integration/plugin-compaction.ts",
    "src/integration/plugin-enforcement-tracking.ts",
    "src/integration/plugin-events.ts",
    "src/integration/plugin-helpers.ts",
    "src/integration/plugin-logging.ts",
    "src/integration/plugin-orchestrator.ts",
    "src/integration/plugin-policy.ts",
    "src/integration/plugin-workspace.ts",

    "src/hooks/shared/obligation-tracker.ts",
    "src/hooks/shared/phase-gate.ts",
    "src/hooks/shared/platform-detect.ts",
    "src/hooks/shared/stdin-reader.ts",
    "src/hooks/shared/stdout-writer.ts",

    "src/mcp-server/schema-converter.ts",
    "src/mcp-server/session-resolver.ts",

    "src/adapters/host-adapter.ts",
    "src/adapters/persistence-lock.ts",

    "src/templates/codex-plugin.ts"
  ],
  "mutator": {
    "excludedMutations": ["StringLiteral"]
  },
  "ignoreStatic": true,
  "thresholds": {
    "high": 90,
    "low": 60,
    "break": 80
  }
}
